# ------------------------------------------------------------------
# ai-tasks — production environment
# Copy to .env.production on the server and fill in REAL values.
# Do NOT commit the filled copy to git.
# ------------------------------------------------------------------

# --- Core ---------------------------------------------------------

# Public URL of the app (must match the domain users hit in the browser).
# Trailing slash is fine to omit. Must be https:// for Web Push to work.
NEXTAUTH_URL=https://tasks.example.com

# Secret for NextAuth JWT / CSRF. Generate with:
#   openssl rand -base64 48
NEXTAUTH_SECRET=__REPLACE_ME__

# Trust X-Forwarded-Host when behind Nginx / Cloudflare Tunnel / any reverse proxy.
# Without this NextAuth v5 rejects requests with UntrustedHost.
AUTH_TRUST_HOST=true

# Salt used when hashing generated API keys. Generate with:
#   openssl rand -hex 32
API_KEY_SALT=__REPLACE_ME__

# Port the Node server binds to. Nginx proxies to this.
PORT=3000

# Ensure Next runs in production mode.
NODE_ENV=production

# --- AI providers -------------------------------------------------

# At least one of these must be set. The active model is selected by AI_MODEL.
OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...

# Model the assistant uses. Examples:
#   gpt-4o-mini, gpt-4o, claude-sonnet-4-5, claude-opus-4-5
AI_MODEL=gpt-4o-mini

# --- Telegram bot (optional) --------------------------------------
# Leave unset to disable the Telegram integration.
TELEGRAM_BOT_TOKEN=

# --- Web Push (VAPID) ---------------------------------------------
# Generate a fresh keypair on the server with:
#   npx web-push generate-vapid-keys
# Public key is bundled into the client at build time.
# VAPID_SUBJECT must be mailto: or a URL — used by push services for abuse contact.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=__REPLACE_ME__
VAPID_PRIVATE_KEY=__REPLACE_ME__
VAPID_SUBJECT=mailto:you@example.com

# --- Supabase migration (OPTIONAL, one-time) ----------------------
# Only needed if you're importing from the old Jarvis/Supabase setup.
# Leave unset otherwise.
# MIGRATION_SUPABASE_URL=
# MIGRATION_SUPABASE_SERVICE_KEY=
# MIGRATION_DEFAULT_USER_ID=
